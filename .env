# ============================================================
# FILL IN YOUR API KEYS BELOW
# ============================================================

# OpenRouter API Key
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=PASTE_YOUR_OPENROUTER_KEY_HERE

# Qdrant Vector DB (leave as-is for local Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================================
# DO NOT CHANGE THESE UNLESS YOU CHANGE PORTS
# ============================================================

# Frontend talks to backend at this URL
# IMPORTANT: Use your machine's IP, not localhost, if accessing from another device
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend allows requests from these origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://172.22.16.1:3000,http://127.0.0.1:3000
